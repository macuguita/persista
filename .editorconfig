root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
tab_width = 4

[*.{kt,kts}]
indent_style = tab
ij_kotlin_name_count_to_use_star_import = 100
ij_kotlin_name_count_to_use_star_import_for_members = 100

[*.bat]
end_of_line = crlf

[*.{json,mcmeta}]
indent_style = space
indent_size = 2